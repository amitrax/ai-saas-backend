# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/ai_saas_db

# JWT Secret Key (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here

# Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyAPqtnrHsRSekfxKrcjrVjwsJKIbjFJDlA

# HuggingFace API Key (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Flask Configuration
FLASK_DEBUG=True
FLASK_PORT=5000

# Gmail SMTP — used to send OTP verification and password-reset emails
# STEP 1: Enable 2-Step Verification on your Google account
# STEP 2: Go to https://myaccount.google.com/apppasswords
# STEP 3: Create an App Password (Mail / Other → name it "NeuralForge")
# STEP 4: Paste the 16-char password below (NOT your normal Gmail password)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Frontend URL (used for password-reset deep links)
FRONTEND_URL=http://localhost:3000
